# Generated target shape for `.env.page-builder.local`.
# Preferred workflow: edit `.env.client.local`, then run
# `node SCRIPTS/bootstrap-client-config.js --write`.

PAGE_BUILDER_WORDPRESS_BASE_URL="https://example.test"
PAGE_BUILDER_WORDPRESS_USERNAME="your-wordpress-username"
PAGE_BUILDER_WORDPRESS_APPLICATION_PASSWORD="your-wordpress-application-password"

PAGE_BUILDER_FIREBASE_PROJECT_ID="your-firebase-project-id"
PAGE_BUILDER_FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
PAGE_BUILDER_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"

# Optional overrides
# PAGE_BUILDER_FIREBASE_DRAFT_COLLECTION="pageBuilderDrafts"
# PAGE_BUILDER_FIREBASE_DATABASE_ID="(default)"
# PAGE_BUILDER_FIREBASE_APP_NAME="page-builder-runtime"# Local page-builder runtime config
#
# Copy this file to `.env.page-builder.local` in the repo root.
# The runtime CLI auto-loads that file by default, so you do not need to export
# these variables manually in every terminal session.
#
# Real secrets must stay only in `.env.page-builder.local`, which is already
# ignored by git via `.env.*`.

PAGE_BUILDER_WORDPRESS_BASE_URL="https://example.test"
PAGE_BUILDER_WORDPRESS_USERNAME="your-wordpress-username"
PAGE_BUILDER_WORDPRESS_APPLICATION_PASSWORD="your-wordpress-application-password"

PAGE_BUILDER_FIREBASE_PROJECT_ID="your-firebase-project-id"
PAGE_BUILDER_FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
PAGE_BUILDER_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"

# Optional overrides
# PAGE_BUILDER_FIREBASE_DRAFT_COLLECTION="pageBuilderDrafts"
# PAGE_BUILDER_FIREBASE_DATABASE_ID="(default)"
# PAGE_BUILDER_FIREBASE_APP_NAME="page-builder-runtime"