---
import type { RestaurantMenuDrawerTypeBlock } from '../lib/types';

interface Props {
  section: RestaurantMenuDrawerTypeBlock;
}

const { section } = Astro.props;
const intro = section.data.intro;
const shouldRenderPrimaryCta = intro.buttonLabel.trim().length > 0 && intro.buttonTarget.trim().length > 0;
const shouldRenderIntroImage = intro.imageUrl.trim().length > 0;
const configuredWordPressBaseUrl = (
  ((import.meta as ImportMeta & { env?: Record<string, string | undefined> }).env?.PUBLIC_WORDPRESS_BASE_URL)
    ?? process.env.PUBLIC_WORDPRESS_BASE_URL
    ?? process.env.CLIENT_WORDPRESS_BASE_URL
    ?? ''
).trim();

const serializedPayload = JSON.stringify({
  title: intro.heading,
  description: intro.description,
  collections: section.data.collections.map((collection) => ({
    title: collection.collectionTitle,
    description: collection.collectionDescription,
    buttonLabel: collection.buttonLabel,
    wooCategoryIds: collection.wooCategoryIds,
  })),
}).replace(/</g, '\\u003c');
---

<section
  class="restaurant-menu-drawer-type"
  data-restaurant-menu-drawer
  data-wordpress-base-url={configuredWordPressBaseUrl}
  data-section-id={section.id}
>
  <script type="application/json" data-restaurant-menu-drawer-payload set:html={serializedPayload}></script>

  <div class="restaurant-menu-drawer-type__inner theme-section-wrapper">
    <div class="restaurant-menu-drawer-type__layout">
      <div class="restaurant-menu-drawer-type__intro-column">
        <div class="restaurant-menu-drawer-type__intro-copy">
          <h2 class="restaurant-menu-drawer-type__title">{intro.heading}</h2>
          <div class="restaurant-menu-drawer-type__rule" aria-hidden="true"></div>
          <p class="restaurant-menu-drawer-type__description">{intro.description}</p>

          {shouldRenderPrimaryCta ? (
            <a class="restaurant-menu-drawer-type__primary-cta" href={intro.buttonTarget}>{intro.buttonLabel}</a>
          ) : null}

          {shouldRenderIntroImage ? (
            <div class="restaurant-menu-drawer-type__intro-image-frame">
              <img
                src={intro.imageUrl}
                alt={intro.imageAlt.trim().length > 0 ? intro.imageAlt : intro.heading}
                loading="lazy"
              />
            </div>
          ) : null}
        </div>
      </div>

      <div class="restaurant-menu-drawer-type__cards-column">
        <div class="restaurant-menu-drawer-type__cards-grid">
          {section.data.collections.map((collection, index) => {
            const hasVisual = Boolean(collection.visualUrl?.trim());

            return (
              <button
                type="button"
                class="restaurant-menu-drawer-type__card"
                data-collection-trigger
                data-collection-index={String(index)}
                aria-label={`Open ${collection.collectionTitle} drawer`}
              >
                <div class="restaurant-menu-drawer-type__card-content">
                  {hasVisual ? (
                    <div class="restaurant-menu-drawer-type__card-image-frame">
                      <img src={collection.visualUrl} alt={collection.collectionTitle} loading="lazy" />
                    </div>
                  ) : null}

                  <div class="restaurant-menu-drawer-type__card-copy">
                    <h3 class="restaurant-menu-drawer-type__card-title">{collection.collectionTitle}</h3>
                    <p class="restaurant-menu-drawer-type__card-description">{collection.collectionDescription}</p>
                  </div>

                  <span class="restaurant-menu-drawer-type__card-link">
                    {collection.buttonLabel}
                    <span aria-hidden="true">-&gt;</span>
                  </span>
                </div>
              </button>
            );
          })}
        </div>
      </div>
    </div>
  </div>

  <div class="restaurant-menu-drawer-type__drawer-shell" data-drawer-shell data-state="closed" aria-hidden="true">
    <button
      type="button"
      class="restaurant-menu-drawer-type__drawer-backdrop"
      data-drawer-close
      aria-label="Close drawer"
      tabindex="-1"
    ></button>

    <div class="restaurant-menu-drawer-type__drawer-panel" role="dialog" aria-modal="true" aria-labelledby={`${section.id}-drawer-title`}>
      <button type="button" class="restaurant-menu-drawer-type__drawer-close" data-drawer-close aria-label="Close drawer">
        Close
      </button>

      <div class="restaurant-menu-drawer-type__drawer-content">
        <div class="restaurant-menu-drawer-type__drawer-header">
          <h3 id={`${section.id}-drawer-title`} class="restaurant-menu-drawer-type__drawer-title" data-drawer-title>{intro.heading}</h3>
          <p class="restaurant-menu-drawer-type__drawer-description" data-drawer-description>{intro.description}</p>
        </div>

        <div class="restaurant-menu-drawer-type__drawer-status" data-drawer-status hidden></div>
        <div class="restaurant-menu-drawer-type__drawer-sections" data-drawer-sections></div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const RESTAURANT_MENU_DRAWER_PILL_LABELS = {
    '500-ml': '500 ml',
    vegan: 'Vegan',
    vege: 'Vege',
    ostre: 'Ostre',
    'bardzo-ostre': 'Bardzo ostre',
  };

  const escapeHtml = (value) => String(value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');

  const getOptionalText = (value) => {
    if (typeof value !== 'string') {
      return null;
    }

    const trimmed = value.trim();
    return trimmed.length > 0 ? trimmed : null;
  };

  const normalizeMetadataValue = (value) => value
    .trim()
    .toLowerCase()
    .replace(/\s+/g, '-')
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '');

  const getMenuItemPills = (tagSlugs) => {
    if (!Array.isArray(tagSlugs) || tagSlugs.length === 0) {
      return [];
    }

    const uniquePills = new Map();

    for (const tagSlug of tagSlugs) {
      const safeTag = getOptionalText(tagSlug);

      if (!safeTag) {
        continue;
      }

      const normalized = normalizeMetadataValue(safeTag);

      if (!uniquePills.has(normalized)) {
        uniquePills.set(normalized, safeTag);
      }
    }

    return Array.from(uniquePills.entries()).map(([slug, label]) => ({
      slug,
      label: RESTAURANT_MENU_DRAWER_PILL_LABELS[slug] ?? label,
    }));
  };

  const stripHtml = (value) => String(value ?? '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();

  const formatPrice = (prices) => {
    const amount = Number(prices?.price ?? 0) / (10 ** Number(prices?.currency_minor_unit ?? 2));
    const currencyCode = typeof prices?.currency_code === 'string' ? prices.currency_code : 'PLN';

    return new Intl.NumberFormat('pl-PL', {
      style: 'currency',
      currency: currencyCode,
    }).format(amount);
  };

  const splitIntoColumns = (items, count) => {
    if (!Array.isArray(items) || items.length === 0) {
      return [];
    }

    const columnCount = Math.max(1, Number(count) || 1);
    const itemsPerColumn = Math.ceil(items.length / columnCount);

    return Array.from({ length: columnCount }, (_, index) => ({
      items: items.slice(index * itemsPerColumn, (index + 1) * itemsPerColumn),
    })).filter((column) => column.items.length > 0);
  };

  const renderMenuColumns = (menuColumns, emptyStateText) => {
    if (!Array.isArray(menuColumns) || menuColumns.length === 0) {
      return `<p class="restaurant-menu-drawer-type__drawer-empty">${escapeHtml(emptyStateText)}</p>`;
    }

    return `
      <div class="restaurant-menu-drawer-type__menu-grid">
        ${menuColumns.map((column) => `
          <div class="restaurant-menu-drawer-type__menu-column">
            ${column.items.map((item) => {
              const description = getOptionalText(item.description);
              const pills = getMenuItemPills(item.tagSlugs);
              const detailsMarkup = description || pills.length > 0
                ? `
                  <div class="restaurant-menu-drawer-type__menu-details">
                    ${description ? `<p class="restaurant-menu-drawer-type__menu-description">${escapeHtml(description)}</p>` : ''}
                    ${pills.length > 0 ? `
                      <div class="restaurant-menu-drawer-type__menu-pills" data-menu-item-pills>
                        ${pills.map((pill) => `<span class="restaurant-menu-drawer-type__menu-pill">${escapeHtml(pill.label)}</span>`).join('')}
                      </div>
                    ` : ''}
                  </div>
                `
                : '';

              return `
                <div class="restaurant-menu-drawer-type__menu-item">
                  <div class="restaurant-menu-drawer-type__menu-copy">
                    <span class="restaurant-menu-drawer-type__menu-title">${escapeHtml(item.title)}</span>
                    ${detailsMarkup}
                  </div>
                  <div class="restaurant-menu-drawer-type__menu-price-row">
                    <div class="restaurant-menu-drawer-type__menu-leader" aria-hidden="true"></div>
                    <span class="restaurant-menu-drawer-type__menu-price">${escapeHtml(item.priceLabel)}</span>
                  </div>
                </div>
              `;
            }).join('')}
          </div>
        `).join('')}
      </div>
    `;
  };

  const renderDrawerSections = (sections) => sections.map((section) => `
    <section class="restaurant-menu-drawer-type__drawer-section">
      <h4 class="restaurant-menu-drawer-type__drawer-section-heading">${escapeHtml(section.heading)}</h4>
      ${renderMenuColumns(section.menuColumns, section.emptyStateText || 'Brak pozycji w tej sekcji.')}
    </section>
  `).join('');

  const fetchJson = async (url, signal) => {
    const response = await fetch(url, {
      method: 'GET',
      signal,
      headers: {
        Accept: 'application/json',
      },
    });

    if (!response.ok) {
      throw new Error(`Woo Store API request failed: ${response.status} ${response.statusText}`);
    }

    return response.json();
  };

  const mapWooProductToMenuItem = (product) => ({
    title: product.name,
    description: stripHtml(product.short_description || product.description) || undefined,
    priceLabel: formatPrice(product.prices),
    tagSlugs: Array.isArray(product.tags)
      ? product.tags
        .map((tag) => tag?.name || tag?.slug)
        .filter((tagLabel) => typeof tagLabel === 'string' && tagLabel.trim().length > 0)
      : [],
  });

  const initializeRestaurantMenuDrawer = (root) => {
    if (!(root instanceof HTMLElement) || root.dataset.drawerInitialized === 'true') {
      return;
    }

    root.dataset.drawerInitialized = 'true';

    const payloadScript = root.querySelector('[data-restaurant-menu-drawer-payload]');
    const drawerShell = root.querySelector('[data-drawer-shell]');
    const drawerSections = root.querySelector('[data-drawer-sections]');
    const drawerStatus = root.querySelector('[data-drawer-status]');
    const triggerButtons = Array.from(root.querySelectorAll('[data-collection-trigger]'));
    const closeButtons = Array.from(root.querySelectorAll('[data-drawer-close]'));

    if (!(payloadScript instanceof HTMLScriptElement)
      || !(drawerShell instanceof HTMLElement)
      || !(drawerSections instanceof HTMLElement)
      || !(drawerStatus instanceof HTMLElement)) {
      return;
    }

    let payload;

    try {
      payload = JSON.parse(payloadScript.textContent || '{}');
    } catch {
      return;
    }

    const collections = Array.isArray(payload.collections) ? payload.collections : [];
    const baseUrl = root.dataset.wordpressBaseUrl && root.dataset.wordpressBaseUrl.trim().length > 0
      ? root.dataset.wordpressBaseUrl.replace(/\/$/, '')
      : window.location.origin;
    let activeController = null;

    const setDrawerState = (isOpen) => {
      drawerShell.dataset.state = isOpen ? 'open' : 'closed';
      drawerShell.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
      document.body.style.overflow = isOpen ? 'hidden' : '';
    };

    const setStatus = (message) => {
      const safeMessage = getOptionalText(message);
      drawerStatus.hidden = !safeMessage;
      drawerStatus.textContent = safeMessage || '';
    };

    const resolveSectionsByCategoryIds = async (categoryIds, signal) => {
      const sanitizedIds = Array.isArray(categoryIds)
        ? categoryIds.filter((categoryId) => Number.isInteger(categoryId) && categoryId > 0)
        : [];

      if (sanitizedIds.length === 0) {
        return [];
      }

      const categories = await fetchJson(`${baseUrl}/wp-json/wc/store/v1/products/categories?per_page=100`, signal);

      return Promise.all(sanitizedIds.map(async (categoryId) => {
        const category = Array.isArray(categories)
          ? categories.find((candidate) => Number(candidate?.id) === categoryId)
          : null;

        if (!category) {
          throw new Error(`Woo category not found for identifier: ${String(categoryId)}`);
        }

        const params = new URLSearchParams({
          category: String(category.id),
          per_page: '20',
        });
        const products = await fetchJson(`${baseUrl}/wp-json/wc/store/v1/products?${params.toString()}`, signal);

        return {
          heading: category.name,
          menuColumns: splitIntoColumns(
            Array.isArray(products) ? products.map(mapWooProductToMenuItem) : [],
            1,
          ),
          emptyStateText: 'Brak pozycji w tej sekcji.',
        };
      }));
    };

    const openDrawerForCollection = async (collectionIndex) => {
      const collection = collections[collectionIndex];

      if (!collection) {
        return;
      }

      if (activeController) {
        activeController.abort();
      }

      activeController = new AbortController();
      setDrawerState(true);
      setStatus('Ladowanie menu...');
      drawerSections.innerHTML = '';

      try {
        const sections = await resolveSectionsByCategoryIds(collection.wooCategoryIds, activeController.signal);

        if (activeController.signal.aborted) {
          return;
        }

        setStatus('');

        if (sections.length === 0) {
          drawerSections.innerHTML = '<p class="restaurant-menu-drawer-type__drawer-empty">Brak pozycji w tej sekcji.</p>';
          return;
        }

        drawerSections.innerHTML = renderDrawerSections(sections);
      } catch (error) {
        if (activeController.signal.aborted) {
          return;
        }

        drawerSections.innerHTML = '';
        setStatus(error instanceof Error && error.message.trim().length > 0 ? error.message : 'Nie udalo sie zaladowac menu.');
      }
    };

    const closeDrawer = () => {
      if (activeController) {
        activeController.abort();
        activeController = null;
      }

      setDrawerState(false);
      setStatus('');
    };

    triggerButtons.forEach((button) => {
      if (!(button instanceof HTMLElement)) {
        return;
      }

      button.addEventListener('click', () => {
        const collectionIndex = Number(button.dataset.collectionIndex || '-1');
        void openDrawerForCollection(collectionIndex);
      });
    });

    closeButtons.forEach((button) => {
      if (button instanceof HTMLElement) {
        button.addEventListener('click', closeDrawer);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && drawerShell.dataset.state === 'open') {
        closeDrawer();
      }
    });
  };

  document.querySelectorAll('[data-restaurant-menu-drawer]').forEach((root) => {
    initializeRestaurantMenuDrawer(root);
  });
</script>

<style>
  .restaurant-menu-drawer-type {
    background: var(--color-background);
    padding: 8rem 0;
  }

  .restaurant-menu-drawer-type__layout {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .restaurant-menu-drawer-type__intro-column {
    align-self: flex-start;
  }

  .restaurant-menu-drawer-type__intro-copy {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .restaurant-menu-drawer-type__title,
  .restaurant-menu-drawer-type__description,
  .restaurant-menu-drawer-type__card-title,
  .restaurant-menu-drawer-type__card-description,
  .restaurant-menu-drawer-type__drawer-title,
  .restaurant-menu-drawer-type__drawer-description,
  .restaurant-menu-drawer-type__drawer-section-heading,
  .restaurant-menu-drawer-type__drawer-status,
  .restaurant-menu-drawer-type__drawer-empty,
  .restaurant-menu-drawer-type__menu-title,
  .restaurant-menu-drawer-type__menu-description,
  .restaurant-menu-drawer-type__menu-price {
    margin: 0;
  }

  .restaurant-menu-drawer-type__title {
    color: var(--color-on-surface);
    font-family: var(--font-headline);
    font-size: clamp(2.75rem, 4vw, 4.75rem);
    font-weight: 400;
    letter-spacing: 0.08em;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .restaurant-menu-drawer-type__rule {
    width: 3rem;
    height: 1px;
    background: var(--color-primary);
  }

  .restaurant-menu-drawer-type__description,
  .restaurant-menu-drawer-type__card-description,
  .restaurant-menu-drawer-type__drawer-description,
  .restaurant-menu-drawer-type__drawer-status,
  .restaurant-menu-drawer-type__drawer-empty,
  .restaurant-menu-drawer-type__menu-description,
  .restaurant-menu-drawer-type__menu-pill {
    color: var(--color-muted-foreground);
    font-family: var(--font-body);
    line-height: 1.75;
  }

  .restaurant-menu-drawer-type__description,
  .restaurant-menu-drawer-type__drawer-description {
    max-width: 38rem;
    font-size: 1.0625rem;
  }

  .restaurant-menu-drawer-type__primary-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    border-radius: 999px;
    background: var(--color-primary);
    color: var(--color-on-primary);
    font-family: var(--font-label);
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    line-height: 1;
    padding: 1rem 2rem;
    text-decoration: none;
    text-transform: uppercase;
    transition: opacity 180ms ease;
  }

  .restaurant-menu-drawer-type__primary-cta:hover {
    opacity: 0.82;
  }

  .restaurant-menu-drawer-type__intro-image-frame,
  .restaurant-menu-drawer-type__card-image-frame {
    overflow: hidden;
    background: var(--color-surface-container-low);
  }

  .restaurant-menu-drawer-type__intro-image-frame img,
  .restaurant-menu-drawer-type__card-image-frame img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .restaurant-menu-drawer-type__intro-image-frame {
    max-width: 24rem;
  }

  .restaurant-menu-drawer-type__intro-image-frame img {
    aspect-ratio: 4 / 5;
  }

  .restaurant-menu-drawer-type__cards-grid {
    column-count: 1;
    column-gap: 1.5rem;
  }

  .restaurant-menu-drawer-type__card {
    break-inside: avoid;
    display: block;
    width: 100%;
    margin-bottom: 1.5rem;
    border: 0;
    background: var(--color-surface);
    color: inherit;
    cursor: pointer;
    padding: 0;
    text-align: left;
    transition: background-color 220ms ease;
  }

  .restaurant-menu-drawer-type__card:hover,
  .restaurant-menu-drawer-type__card:focus-visible {
    background: var(--color-surface-container-low);
    outline: none;
  }

  .restaurant-menu-drawer-type__card-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 2.5rem;
  }

  .restaurant-menu-drawer-type__card-image-frame img {
    aspect-ratio: 4 / 3;
  }

  .restaurant-menu-drawer-type__card-copy {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .restaurant-menu-drawer-type__card-title,
  .restaurant-menu-drawer-type__drawer-title {
    color: var(--color-on-surface);
    font-family: var(--font-headline);
    font-weight: 400;
    letter-spacing: 0.08em;
    line-height: 1.02;
    text-transform: uppercase;
  }

  .restaurant-menu-drawer-type__card-title {
    font-size: clamp(1.75rem, 2.5vw, 2rem);
  }

  .restaurant-menu-drawer-type__card-link,
  .restaurant-menu-drawer-type__drawer-section-heading,
  .restaurant-menu-drawer-type__menu-title,
  .restaurant-menu-drawer-type__menu-price,
  .restaurant-menu-drawer-type__menu-description,
  .restaurant-menu-drawer-type__menu-pill,
  .restaurant-menu-drawer-type__drawer-close,
  .restaurant-menu-drawer-type__drawer-empty,
  .restaurant-menu-drawer-type__drawer-status {
    font-family: var(--font-label);
    letter-spacing: 0.04em;
  }

  .restaurant-menu-drawer-type__card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-muted-foreground);
    font-size: 0.6875rem;
    text-transform: uppercase;
  }

  .restaurant-menu-drawer-type__drawer-shell {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 60;
  }

  .restaurant-menu-drawer-type__drawer-shell[data-state='open'] {
    pointer-events: auto;
  }

  .restaurant-menu-drawer-type__drawer-backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    background: rgba(0, 0, 0, 0.28);
    opacity: 0;
    transition: opacity 220ms ease;
  }

  .restaurant-menu-drawer-type__drawer-shell[data-state='open'] .restaurant-menu-drawer-type__drawer-backdrop {
    opacity: 1;
  }

  .restaurant-menu-drawer-type__drawer-panel {
    position: absolute;
    top: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    width: min(100vw, 56rem);
    height: 100%;
    background: #ffffff;
    box-shadow: -24px 0 60px rgba(0, 0, 0, 0.08);
    transform: translateX(100%);
    transition: transform 320ms ease;
  }

  .restaurant-menu-drawer-type__drawer-shell[data-state='open'] .restaurant-menu-drawer-type__drawer-panel {
    transform: translateX(0);
  }

  .restaurant-menu-drawer-type__drawer-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    border: 1px solid color-mix(in srgb, var(--color-foreground) 18%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-surface-container-low) 82%, white);
    color: var(--color-muted-foreground);
    cursor: pointer;
    font-size: 0.75rem;
    line-height: 1;
    padding: 0.9rem 1rem;
    text-transform: uppercase;
  }

  .restaurant-menu-drawer-type__drawer-content {
    height: 100%;
    overflow-y: auto;
    padding: 5.5rem 2rem 3rem;
  }

  .restaurant-menu-drawer-type__drawer-header {
    border-bottom: 1px solid color-mix(in srgb, var(--color-foreground) 10%, transparent);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-bottom: 2rem;
  }

  .restaurant-menu-drawer-type__drawer-title {
    font-size: clamp(2.25rem, 3vw, 3.75rem);
    line-height: 0.92;
  }

  .restaurant-menu-drawer-type__drawer-status,
  .restaurant-menu-drawer-type__drawer-sections {
    margin-top: 2.5rem;
  }

  .restaurant-menu-drawer-type__drawer-status,
  .restaurant-menu-drawer-type__drawer-empty {
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .restaurant-menu-drawer-type__drawer-sections {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .restaurant-menu-drawer-type__drawer-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .restaurant-menu-drawer-type__drawer-section-heading {
    color: var(--color-muted-foreground);
    font-size: 0.6875rem;
    text-transform: uppercase;
  }

  .restaurant-menu-drawer-type__menu-grid {
    display: grid;
