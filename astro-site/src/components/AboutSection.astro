---
interface ImageAsset {
  src: string;
  alt: string;
}

interface CtaButton {
  href: string;
  text: string;
}

interface TextContent {
  title?: string;
  paragraphs?: string[];
  ctaButton?: CtaButton;
}

interface Props {
  leftImages?: ImageAsset[];
  leftText?: TextContent;
  rightText?: TextContent;
  rightImages?: ImageAsset[];
}

const {
  leftImages = [],
  leftText = { paragraphs: [] },
  rightText = { paragraphs: [] },
  rightImages = [],
} = Astro.props;

const hasLeftText = Boolean(leftText.title) || (leftText.paragraphs?.length ?? 0) > 0;
const hasRightText = Boolean(rightText.title) || (rightText.paragraphs?.length ?? 0) > 0;
---

<section class="about-section">
  <div class="about-section__inner">
    <div class="about-section__grid">
      <div class="about-section__column about-section__column--primary">
        {leftImages.length > 0 ? (
          <div class="about-section__media-stack" aria-label="Zdjecia sekcji o restauracji">
            {leftImages.map((image, index) => (
              <div class="about-section__image-frame">
                <img src={image.src} alt={image.alt} loading={index === 0 ? 'eager' : 'lazy'} />
              </div>
            ))}
          </div>
        ) : null}

        {hasLeftText ? (
          <div class="about-section__copy">
            {leftText.title ? <h2 class="about-section__title">{leftText.title}</h2> : null}
            {leftText.paragraphs?.length ? (
              <div class="about-section__body">
                {leftText.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            ) : null}
            {leftText.ctaButton ? (
              <a class="about-section__button" href={leftText.ctaButton.href}>{leftText.ctaButton.text}</a>
            ) : null}
          </div>
        ) : null}
      </div>

      <div class="about-section__column about-section__column--secondary">
        {hasRightText ? (
          <div class="about-section__copy about-section__copy--secondary">
            {rightText.title ? <h2 class="about-section__title">{rightText.title}</h2> : null}
            {rightText.paragraphs?.length ? (
              <div class="about-section__body">
                {rightText.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            ) : null}
          </div>
        ) : null}

        {rightImages.length > 0 ? (
          <div class="about-section__media-stack about-section__media-stack--secondary" aria-label="Dodatkowe zdjecia sekcji o restauracji">
            {rightImages.map((image) => (
              <div class="about-section__image-frame">
                <img src={image.src} alt={image.alt} loading="lazy" />
              </div>
            ))}
          </div>
        ) : null}
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    background: var(--color-surface-container-lowest);
    color: var(--color-on-surface);
    padding-top: 8rem;
    padding-bottom: 8rem;
  }

  .about-section__inner {
    box-sizing: border-box;
  }

  .about-section__grid {
    display: flex;
    flex-direction: column-reverse;
    gap: 2rem;
  }

  .about-section__column {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .about-section__media-stack {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .about-section__image-frame {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    aspect-ratio: 4 / 3;
    background: var(--color-surface-container-low);
  }

  .about-section__image-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-section__copy {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .about-section__title {
    margin: 0;
    font-family: var(--font-headline);
    font-size: 2.25rem;
    font-weight: 400;
    letter-spacing: 0.3rem;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .about-section__body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    color: var(--color-secondary);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.8;
  }

  .about-section__body p {
    margin: 0;
  }

  .about-section__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    border-radius: 4px;
    background: var(--color-primary);
    color: var(--color-on-primary);
    padding: 1rem 2rem;
    font-family: var(--font-label);
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: opacity 0.2s ease;
  }

  .about-section__button:hover {
    opacity: 0.8;
  }

  @media (min-width: 1024px) {
    .about-section__grid {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
      align-items: start;
      gap: 3.5rem;
    }

    .about-section__column {
      gap: 4rem;
    }
  }

  @media (max-width: 767px) {
    .about-section {
      padding-top: 5rem;
      padding-bottom: 5rem;
    }

    .about-section__title {
      font-size: 1.75rem;
      letter-spacing: 0.18rem;
    }
  }
</style>