---
interface PrimaryCta {
  text: string;
  href?: string;
}

interface ServiceCard {
  icon: string;
  title: string;
  description: string;
  ctaText: string;
  ctaHref: string;
}

interface Props {
  title: string;
  description: string;
  primaryCta?: PrimaryCta;
  cards?: ServiceCard[];
}

const { title, description, primaryCta, cards = [] } = Astro.props;

const SERVICE_ICON_SVG_MAP: Record<string, string> = {
  celebration: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 5v4"></path><path d="M16 3v6"></path><path d="M12 7v3"></path><path d="M5 12c2.5 0 4.5 2 4.5 4.5S7.5 21 5 21"></path><path d="M19 12c-2.5 0-4.5 2-4.5 4.5S16.5 21 19 21"></path><path d="M8 13c1.5 1 2.7 2.3 4 4 1.3-1.7 2.5-3 4-4"></path></svg>',
  local_shipping: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h11v8H3Z"></path><path d="M14 10h3l4 4v1h-7Z"></path><path d="M7 19a2 2 0 1 0 0 .01"></path><path d="M18 19a2 2 0 1 0 0 .01"></path></svg>',
  groups: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7.5 12a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"></path><path d="M16.5 11a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"></path><path d="M3 19a4.5 4.5 0 0 1 9 0"></path><path d="M13 19a3.5 3.5 0 0 1 7 0"></path></svg>',
  default: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8"></circle><path d="M12 8v4l2.5 2.5"></path></svg>',
};

const getServiceIconSvg = (icon: string) => SERVICE_ICON_SVG_MAP[icon] ?? SERVICE_ICON_SVG_MAP.default;
---

<section class="services-section">
  <div class="services-section__inner theme-section-wrapper">
    <div class="services-section__intro">
      <h2 class="services-section__title">{title}</h2>
      <div class="services-section__rule" aria-hidden="true"></div>
      <p class="services-section__description">{description}</p>

      {primaryCta ? (
        primaryCta.href ? (
          <a class="services-section__button" href={primaryCta.href}>{primaryCta.text}</a>
        ) : (
          <span class="services-section__button">{primaryCta.text}</span>
        )
      ) : null}
    </div>

    <div class="services-section__cards">
      {cards.map((card) => (
        <article class="services-section__card">
          <span class="services-section__card-icon" aria-hidden="true" set:html={getServiceIconSvg(card.icon)}></span>

          <div class="services-section__card-copy">
            <h3 class="services-section__card-title">{card.title}</h3>
            <p class="services-section__card-description">{card.description}</p>
          </div>

          <a class="services-section__card-link" href={card.ctaHref}>
            {card.ctaText}
            <span class="services-section__card-arrow" aria-hidden="true">&rarr;</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    background: var(--color-surface-container-lowest);
    color: var(--color-on-surface);
    padding-top: 8rem;
    padding-bottom: 8rem;
  }

  .services-section__inner {
    display: grid;
    gap: 3rem;
  }

  .services-section__intro {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    max-width: 28rem;
  }

  .services-section__title {
    margin: 0;
    font-family: var(--font-headline);
    font-size: 2.25rem;
    font-weight: 400;
    letter-spacing: 0.3rem;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .services-section__rule {
    width: 3rem;
    height: 1px;
    background: var(--color-primary);
  }

  .services-section__description {
    margin: 0;
    color: var(--color-secondary);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.8;
  }

  .services-section__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    border-radius: 4px;
    background: var(--color-primary);
    color: var(--color-on-primary);
    padding: 1rem 2rem;
    font-family: var(--font-label);
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: opacity 0.2s ease;
  }

  .services-section__button:hover {
    opacity: 0.8;
  }

  .services-section__cards {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .services-section__card {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    min-height: 100%;
    background: var(--color-surface);
    padding: 2.5rem;
    transition: background-color 0.2s ease;
  }

  .services-section__card:hover {
    background: var(--color-surface-container-low);
  }

  .services-section__card-icon {
    display: inline-flex;
    width: 2rem;
    height: 2rem;
    color: rgba(27, 28, 28, 0.6);
  }

  .services-section__card-icon :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .services-section__card-copy {
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    gap: 1rem;
  }

  .services-section__card-title {
    margin: 0;
    font-family: var(--font-headline);
    font-size: 1.125rem;
    font-weight: 400;
    letter-spacing: 0.15rem;
    text-transform: uppercase;
  }

  .services-section__card-description {
    margin: 0;
    color: var(--color-secondary);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.8;
  }

  .services-section__card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-secondary);
    font-family: var(--font-label);
    font-size: 0.75rem;
    letter-spacing: 0.15rem;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }

  .services-section__card-link:hover {
    color: var(--color-on-surface);
  }

  .services-section__card-arrow {
    font-size: 0.875rem;
    line-height: 1;
  }

  @media (min-width: 1024px) {
    .services-section__inner {
      grid-template-columns: minmax(18rem, 24rem) minmax(0, 1fr);
      align-items: start;
      gap: 4rem;
    }

    .services-section__intro {
      position: sticky;
      top: 8rem;
    }

    .services-section__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 767px) {
    .services-section {
      padding-top: 5rem;
      padding-bottom: 5rem;
    }

    .services-section__title {
      font-size: 1.75rem;
      letter-spacing: 0.18rem;
    }

    .services-section__card {
      padding: 2rem;
    }
  }
</style>