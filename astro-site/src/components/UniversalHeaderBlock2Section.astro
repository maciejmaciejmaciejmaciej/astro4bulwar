---
interface MetadataItem {
  label: string;
  value: string;
}

interface ContactCta {
  label: string;
  buttonLabel: string;
  href: string;
}

interface HeroImage {
  src: string;
  alt: string;
}

interface StorySection {
  number: string;
  title: string;
  content: string;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  metadataItems?: MetadataItem[];
  contactCta?: ContactCta;
  heroImage: HeroImage;
  storySections?: StorySection[];
}

const {
  eyebrow,
  title,
  description,
  metadataItems = [],
  contactCta,
  heroImage,
  storySections = [],
} = Astro.props;
---

<section class="universal-header-block-2">
  <div class="universal-header-block-2__inner theme-section-wrapper">
    <header class="universal-header-block-2__header">
      <div class="universal-header-block-2__header-grid">
        <div class="universal-header-block-2__intro">
          <p class="universal-header-block-2__eyebrow">{eyebrow}</p>

          <div class="universal-header-block-2__title-group">
            <h2 class="universal-header-block-2__title">{title}</h2>
            <div class="universal-header-block-2__rule" aria-hidden="true"></div>
          </div>

          <p class="universal-header-block-2__description">{description}</p>
        </div>

        <div class="universal-header-block-2__meta">
          {metadataItems.map((item) => (
            <div class="universal-header-block-2__meta-item">
              <p class="universal-header-block-2__meta-label">{item.label}</p>
              <p class="universal-header-block-2__meta-value">{item.value}</p>
            </div>
          ))}

          {contactCta ? (
            <div class="universal-header-block-2__cta-group">
              <p class="universal-header-block-2__meta-label">{contactCta.label}</p>
              <a class="universal-header-block-2__cta theme-radius-control" href={contactCta.href}>{contactCta.buttonLabel}</a>
            </div>
          ) : null}
        </div>
      </div>
    </header>

    <div class="universal-header-block-2__image-frame theme-radius-media">
      <img src={heroImage.src} alt={heroImage.alt} loading="eager" />
    </div>

    {storySections.length > 0 ? (
      <div class="universal-header-block-2__stories">
        {storySections.map((section) => (
          <section class="universal-header-block-2__story-row">
            <div class="universal-header-block-2__story-grid">
              <div class="universal-header-block-2__story-heading">
                <span class="universal-header-block-2__story-number">{section.number}</span>
                <h3 class="universal-header-block-2__story-title">{section.title}</h3>
              </div>

              <div>
                <p class="universal-header-block-2__story-content">{section.content}</p>
              </div>
            </div>
          </section>
        ))}
      </div>
    ) : null}
  </div>
</section>

<style>
  .universal-header-block-2 {
    background: #ffffff;
    color: var(--color-on-surface);
    padding-top: 6rem;
    padding-bottom: 6rem;
  }

  .universal-header-block-2__inner {
  }

  .universal-header-block-2__header {
    border-bottom: 1px solid color-mix(in srgb, var(--color-outline-variant) 20%, transparent);
    padding-bottom: 3rem;
  }

  .universal-header-block-2__header-grid {
    display: grid;
    gap: 2.5rem;
  }

  .universal-header-block-2__intro {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .universal-header-block-2__eyebrow {
    margin: 0;
    color: rgb(113 113 122);
    font-family: var(--font-label);
    font-size: 0.75rem;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
  }

  .universal-header-block-2__title-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .universal-header-block-2__title {
    margin: 0;
    font-family: var(--font-headline);
    font-size: 2.5rem;
    font-weight: 400;
    letter-spacing: 0.25rem;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .universal-header-block-2__rule {
    width: 3rem;
    height: 1px;
    background: var(--color-primary);
  }

  .universal-header-block-2__description {
    margin: 0;
    max-width: 42rem;
    color: rgb(113 113 122);
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.8;
  }

  .universal-header-block-2__meta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .universal-header-block-2__meta-item,
  .universal-header-block-2__cta-group {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    max-width: 20rem;
  }

  .universal-header-block-2__meta-label {
    margin: 0;
    color: rgb(113 113 122);
    font-family: var(--font-label);
    font-size: 0.6875rem;
    letter-spacing: 0.2rem;
    text-transform: uppercase;
  }

  .universal-header-block-2__meta-value {
    margin: 0;
    color: var(--color-on-surface);
    font-family: var(--font-headline);
    font-size: 0.9375rem;
    letter-spacing: 0.04rem;
    line-height: 1.35;
  }

  .universal-header-block-2__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    background: var(--color-primary);
    color: var(--color-on-primary);
    padding: 1rem 2rem;
    font-family: var(--font-label);
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: opacity 0.2s ease;
  }

  .universal-header-block-2__cta:hover {
    opacity: 0.8;
  }

  .universal-header-block-2__image-frame {
    margin-top: 3rem;
    overflow: hidden;
    background: var(--color-surface-container-low);
  }

  .universal-header-block-2__image-frame img {
    display: block;
    width: 100%;
    height: 23.75rem;
    object-fit: cover;
  }

  .universal-header-block-2__stories {
    margin-top: 3rem;
    margin-bottom: 5rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .universal-header-block-2__story-row {
    border-bottom: 1px solid color-mix(in srgb, var(--color-outline-variant) 20%, transparent);
    padding-bottom: 2rem;
  }

  .universal-header-block-2__story-grid {
    display: grid;
    gap: 2rem;
  }

  .universal-header-block-2__story-heading {
    display: flex;
    flex-direction: column;
  }

  .universal-header-block-2__story-number {
    color: rgb(161 161 170);
    font-family: var(--font-headline);
    font-size: 2.5rem;
    font-weight: 300;
    line-height: 1;
  }

  .universal-header-block-2__story-title {
    margin: 1rem 0 0;
    font-family: var(--font-headline);
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: 0.16rem;
    text-transform: uppercase;
  }

  .universal-header-block-2__story-content {
    margin: 0;
    color: rgb(113 113 122);
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.8;
  }

  @media (min-width: 768px) {
    .universal-header-block-2 {
      padding-top: 8rem;
      padding-bottom: 8rem;
    }

    .universal-header-block-2__header {
      padding-bottom: 4rem;
    }

    .universal-header-block-2__title {
      font-size: 3.75rem;
    }

    .universal-header-block-2__description,
    .universal-header-block-2__story-content {
      font-size: 1.125rem;
    }

    .universal-header-block-2__image-frame {
      margin-top: 4rem;
    }

    .universal-header-block-2__image-frame img {
      height: 32.5rem;
    }

    .universal-header-block-2__stories {
      margin-top: 4rem;
      margin-bottom: 6rem;
      gap: 4rem;
    }

    .universal-header-block-2__story-row {
      padding-bottom: 3rem;
    }
  }

  @media (min-width: 1024px) {
    .universal-header-block-2__header-grid {
      grid-template-columns: minmax(0, 1.6fr) minmax(17.5rem, 0.85fr);
      align-items: start;
      gap: 3.5rem;
    }

    .universal-header-block-2__meta {
      align-items: flex-end;
      text-align: right;
    }

    .universal-header-block-2__meta-item,
    .universal-header-block-2__cta-group {
      margin-left: auto;
    }

    .universal-header-block-2__story-grid {
      grid-template-columns: 13.75rem minmax(0, 1fr);
      gap: 3rem;
      align-items: start;
    }

    .universal-header-block-2__story-number {
      font-size: 3.75rem;
    }
  }

  @media (max-width: 767px) {
    .universal-header-block-2__title {
      letter-spacing: 0.18rem;
    }

    .universal-header-block-2__story-title {
      font-size: 1.5rem;
    }
  }
</style>