---
import type { JustPralaxImgHorizontalBlock } from '../lib/types';

interface Props {
  section: JustPralaxImgHorizontalBlock;
}

const { section } = Astro.props;
const { imageUrl } = section.data;
---

<section class="just-pralax-img-horizontal">
  <div class="just-pralax-img-horizontal__shell theme-section-wrapper">
    <div
      class="just-pralax-img-horizontal__image"
      style={`background-image: linear-gradient(rgba(39, 39, 42, 0.5), rgba(39, 39, 42, 0.5)), url('${imageUrl.replace(/'/g, "\\'")}');`}
      aria-label="Parallax image"
    ></div>
  </div>
</section>

<style>
  .just-pralax-img-horizontal {
    width: 100%;
  }

  .just-pralax-img-horizontal__shell {
    display: flex;
  }

  .just-pralax-img-horizontal__image {
    width: 100%;
    max-width: 96rem;
    height: 400px;
    border-radius: var(--radius-media, 1.5rem);
    background-color: var(--color-surface-container-low);
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
  }

  @media (min-width: 1024px) {
    .just-pralax-img-horizontal__image {
      height: 300px;
      background-attachment: fixed;
    }
  }
</style>