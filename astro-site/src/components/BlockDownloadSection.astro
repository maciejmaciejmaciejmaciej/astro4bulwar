---
type FeatureIcon = 'groups' | 'quality' | 'format' | 'events';

interface CtaLink {
  label: string;
  href: string;
}

interface Feature {
  icon: FeatureIcon;
  title: string;
}

interface Props {
  title: string;
  subtitle: string;
  primaryCta: CtaLink;
  secondaryCta: CtaLink;
  helperText: string;
  versionLabel: string;
  fileMeta: string;
  panelCaption: string;
  features?: Feature[];
}

const {
  title,
  subtitle,
  primaryCta,
  secondaryCta,
  helperText,
  versionLabel,
  fileMeta,
  panelCaption,
  features = [],
} = Astro.props;

const FEATURE_ICON_MAP: Record<FeatureIcon, string> = {
  groups: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>',
  quality: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c4-2 6-5.5 6-10V6l-6-4-6 4v6c0 4.5 2 8 6 10Z"></path><path d="m9 12 2 2 4-4"></path></svg>',
  format: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><path d="M14 2v6h6"></path><path d="M16 13H8"></path><path d="M16 17H8"></path><path d="M10 9H8"></path></svg>',
  events: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M3 10h18"></path><path d="m8 14 2 2 4-4"></path></svg>',
};

const DOWNLOAD_ICON = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"></path><path d="m7 10 5 5 5-5"></path><path d="M5 21h14"></path></svg>';
---

<section class="block-download">
  <div class="block-download__shell theme-radius-surface theme-section-wrapper">
    <div class="block-download__copy">
      <div class="block-download__heading">
        <h2 class="block-download__title">{title}</h2>
        <div class="block-download__rule" aria-hidden="true"></div>
        <p class="block-download__subtitle">{subtitle}</p>
      </div>

      <div class="block-download__features">
        {features.map((feature) => (
          <div class="block-download__feature-row">
            <span class="block-download__feature-icon theme-radius-control" aria-hidden="true" set:html={FEATURE_ICON_MAP[feature.icon]}></span>
            <p class="block-download__feature-title">{feature.title}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="block-download__aside">
      <div class="block-download__panel theme-radius-surface">
        <div class="block-download__panel-head">
          <div class="block-download__meta-row">
            <span class="block-download__version">{versionLabel}</span>
            <span class="block-download__separator">•</span>
            <span class="block-download__file-meta">{fileMeta}</span>
          </div>
          <p class="block-download__panel-caption">{panelCaption}</p>
        </div>

        <div class="block-download__panel-body">
          <a class="block-download__primary-cta theme-radius-control" href={primaryCta.href}>
            <span class="block-download__primary-cta-icon" aria-hidden="true" set:html={DOWNLOAD_ICON}></span>
            <span>{primaryCta.label}</span>
          </a>

          <div class="block-download__secondary-group">
            <a class="block-download__secondary-cta" href={secondaryCta.href}>{secondaryCta.label}</a>
            <p class="block-download__helper-text">{helperText}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .block-download {
    background: #ffffff;
    padding-top: 6rem;
    padding-bottom: 6rem;
  }

  .block-download__shell {
    display: grid;
    gap: 2.5rem;
    border: 1px solid color-mix(in srgb, var(--color-outline-variant) 45%, transparent);
    background: #ffffff;
    padding: 1.75rem;
  }

  .block-download__copy {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .block-download__heading {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .block-download__title {
    margin: 0;
    font-family: var(--font-headline);
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: 0.2rem;
    text-transform: uppercase;
  }

  .block-download__rule {
    width: 4rem;
    height: 1px;
    background: var(--color-primary);
  }

  .block-download__subtitle {
    margin: 0;
    max-width: 36rem;
    color: rgb(113 113 122);
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.8;
  }

  .block-download__features {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .block-download__feature-row {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .block-download__feature-icon {
    display: inline-flex;
    width: 2.75rem;
    height: 2.75rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    background: var(--color-surface-container-low);
    color: rgb(113 113 122);
  }

  .block-download__feature-icon :global(svg),
  .block-download__primary-cta-icon :global(svg) {
    display: block;
    width: 1rem;
    height: 1rem;
  }

  .block-download__feature-title {
    margin: 0;
    padding-top: 0.5rem;
    color: var(--color-on-surface);
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .block-download__aside {
    display: flex;
    justify-content: flex-end;
  }

  .block-download__panel {
    width: 100%;
    border: 1px solid color-mix(in srgb, var(--color-outline-variant) 45%, transparent);
    background: var(--color-surface);
    padding: 1.75rem;
    text-align: center;
    box-shadow: 0 6px 24px rgba(15, 23, 42, 0.06);
  }

  .block-download__panel-head {
    border-bottom: 1px solid color-mix(in srgb, var(--color-outline-variant) 45%, transparent);
    padding-bottom: 1.75rem;
  }

  .block-download__meta-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .block-download__version {
    font-family: var(--font-headline);
    font-size: 2rem;
    font-weight: 400;
    color: var(--color-on-surface);
  }

  .block-download__separator,
  .block-download__file-meta,
  .block-download__panel-caption,
  .block-download__helper-text {
    color: rgb(113 113 122);
  }

  .block-download__file-meta,
  .block-download__panel-caption,
  .block-download__helper-text {
    font-family: var(--font-body);
    font-size: 0.875rem;
  }

  .block-download__panel-caption,
  .block-download__helper-text {
    margin: 1rem 0 0;
    line-height: 1.6;
  }

  .block-download__panel-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 1.75rem;
  }

  .block-download__primary-cta {
    display: inline-flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: var(--color-primary);
    color: var(--color-on-primary);
    padding: 1rem 1.5rem;
    font-family: var(--font-label);
    font-size: 1rem;
    transition: opacity 0.2s ease;
  }

  .block-download__primary-cta:hover,
  .block-download__secondary-cta:hover {
    opacity: 0.8;
  }

  .block-download__primary-cta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .block-download__secondary-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .block-download__secondary-cta {
    display: inline-flex;
    justify-content: center;
    font-family: var(--font-label);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-on-surface);
    transition: opacity 0.2s ease;
  }

  @media (min-width: 1024px) {
    .block-download__shell {
      grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.88fr);
      align-items: center;
      gap: 4.5rem;
      padding: 3rem;
    }

    .block-download__copy {
      padding-right: 3rem;
    }

    .block-download__panel {
      max-width: 26.25rem;
      padding: 2.5rem;
    }

    .block-download__title {
      font-size: 3rem;
    }
  }

  @media (max-width: 767px) {
    .block-download {
      padding-top: 4.5rem;
      padding-bottom: 4.5rem;
    }

    .block-download__shell,
    .block-download__panel {
      padding: 1.5rem;
    }

    .block-download__title,
    .block-download__version {
      font-size: 1.75rem;
    }
  }
</style>