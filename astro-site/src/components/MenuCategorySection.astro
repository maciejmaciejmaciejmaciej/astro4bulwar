---
interface MenuItem {
  title: string;
  description?: string;
  priceLabel: string;
  tagSlugs?: string[];
}

interface MenuColumn {
  items: MenuItem[];
}

interface Props {
  heroTitle: string;
  backgroundImageSrc: string;
  backgroundImageAlt: string;
  overlayOpacity?: number;
  heroHeight?: string;
  menuColumns: MenuColumn[];
  emptyStateText?: string;
}

const {
  heroTitle,
  backgroundImageSrc,
  backgroundImageAlt,
  overlayOpacity = 0.2,
  heroHeight = '400px',
  menuColumns,
  emptyStateText = 'Brak pozycji w tej kategorii.',
} = Astro.props;

const safeMenuColumns = menuColumns.length > 0 ? menuColumns : [];

const TAG_ICON_KEYS = ['vegan', 'vege', 'ostre', 'bardzo-ostre'] as const;

type TagIconKey = (typeof TAG_ICON_KEYS)[number];

const TAG_ICON_SVG_MAP: Record<TagIconKey, string> = {
  vegan: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 18 13V4a7 7 0 0 0-7 7v9Z"></path><path d="M7 20a5 5 0 0 1 5-5"></path></svg>',
  vege: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c4-2 6-5.5 6-10V6l-6-4-6 4v6c0 4.5 2 8 6 10Z"></path><path d="M12 22V10"></path><path d="M9 13c1.5-.2 2.5-1.2 3-3 1 1.8 2.2 2.8 4 3"></path></svg>',
  ostre: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 14c0 3 2 6 4 8 2-2 4-5 4-8a4 4 0 0 0-8 0Z"></path><path d="M12 6c0-2 1-3.5 3-5 0 2.5-.4 4.2-1.6 5.5"></path></svg>',
  'bardzo-ostre': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 14c0 3 2 6 4 8 2-2 4-5 4-8a4 4 0 0 0-8 0Z"></path><path d="M12 6c0-2 1-3.5 3-5 0 2.5-.4 4.2-1.6 5.5"></path></svg>',
};

const normalizeTagSlug = (value: string): TagIconKey | null => {
  const normalized = value
    .trim()
    .toLowerCase()
    .replace(/\s+/g, '-')
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '');

  return TAG_ICON_KEYS.includes(normalized as TagIconKey) ? normalized as TagIconKey : null;
};

const getDisplayTags = (tagSlugs: readonly string[] | undefined): TagIconKey[] => {
  if (!tagSlugs || tagSlugs.length === 0) {
    return [];
  }

  const unique = new Set<TagIconKey>();

  for (const tagSlug of tagSlugs) {
    const normalized = normalizeTagSlug(tagSlug);

    if (normalized) {
      unique.add(normalized);
    }
  }

  return Array.from(unique);
};
---

<section class="menu-section">
  <div
    class="menu-section__hero"
    style={`background-image: url('${backgroundImageSrc}'); height: ${heroHeight};`}
    aria-label={backgroundImageAlt}
  >
    <div class="menu-section__overlay" style={`background-color: rgba(0, 0, 0, ${overlayOpacity});`}></div>
    <h2 class="menu-section__hero-title">{heroTitle}</h2>
  </div>

  <div class="menu-section__content">
    <div class="theme-section-wrapper">
      <div class="menu-section__inner">
        {safeMenuColumns.length > 0 ? (
          <div class="menu-section__grid">
            {safeMenuColumns.map((column) => (
              <div class="menu-section__column">
                {column.items.map((item) => {
                  const displayTags = getDisplayTags(item.tagSlugs);

                  return (
                    <div class="menu-section__item">
                      <div class="menu-section__copy">
                        <div class="menu-section__copy-row">
                          {displayTags.length > 0 ? (
                            <div class="menu-section__item-icons" aria-hidden="true">
                              {displayTags.map((tag) => (
                                <span class="menu-section__item-icon" set:html={TAG_ICON_SVG_MAP[tag]}></span>
                              ))}
                            </div>
                          ) : null}

                          <div class="menu-section__copy-text">
                            <span class="menu-section__item-title">{item.title}</span>
                            {item.description ? <p class="menu-section__item-description">{item.description}</p> : null}
                          </div>
                        </div>
                      </div>
                      <div class="menu-leader"></div>
                      <span class="menu-section__item-price">{item.priceLabel}</span>
                    </div>
                  );
                })}
              </div>
            ))}
          </div>
        ) : (
          <p class="menu-section__empty">{emptyStateText}</p>
        )}
      </div>
    </div>
  </div>
</section>