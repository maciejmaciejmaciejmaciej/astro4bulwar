---
import type { HeroSimpleNoTextPy32Block } from '../lib/types';

interface Props {
  section: HeroSimpleNoTextPy32Block;
}

const { section } = Astro.props;
const { imageSrc, alt } = section.data;
---

<section class="hero-simple-no-text-py32">
  <div class="hero-simple-no-text-py32__inner theme-section-wrapper">
    <div class="hero-simple-no-text-py32__media-frame">
      <img src={imageSrc} alt={alt} loading="eager" />
    </div>
    <div class="hero-simple-no-text-py32__divider" aria-hidden="true"></div>
  </div>
</section>

<style>
  .hero-simple-no-text-py32 {
    background: var(--color-background);
    padding-bottom: 3rem;
  }

  .hero-simple-no-text-py32__inner {
    display: flex;
    flex-direction: column;
  }

  .hero-simple-no-text-py32__media-frame {
    position: relative;
    width: 100%;
    max-width: 96rem;
    overflow: hidden;
    border-radius: var(--radius-media, 1.5rem);
    aspect-ratio: 4 / 3;
    background: var(--color-surface-container-low);
  }

  .hero-simple-no-text-py32__media-frame img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-simple-no-text-py32__divider {
    width: 5rem;
    height: 1px;
    margin: 3rem auto 0;
    background: var(--color-foreground, #000);
  }

  @media (min-width: 768px) {
    .hero-simple-no-text-py32__media-frame {
      aspect-ratio: 21 / 9;
      max-height: 650px;
    }
  }
</style>