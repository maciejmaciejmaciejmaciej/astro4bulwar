---
interface TestimonialItem {
  name: string;
  role: string;
  avatar: string;
  content: string;
}

interface Props {
  badge: string;
  title: string;
  description: string;
  firstRow: TestimonialItem[];
  secondRow: TestimonialItem[];
}

const { badge, title, description, firstRow, secondRow } = Astro.props;
---

<section class="testimonial7">
  <div class="testimonial7__inner theme-section-wrapper">
    <div class="testimonial7__header">
      <span class="testimonial7__badge">{badge}</span>
      <h2 class="testimonial7__title">{title}</h2>
      <p class="testimonial7__description">{description}</p>
    </div>

    <div class="testimonial7__rows">
      <div class="testimonial7__track testimonial7__track--forward">
        {[...firstRow, ...firstRow].map((item, index) => (
          <article class="testimonial7__card" aria-label={`Opinia ${item.name}`}>
            <div class="testimonial7__person">
              <img src={item.avatar} alt={item.name} loading={index < firstRow.length ? 'eager' : 'lazy'} />
              <div>
                <p class="testimonial7__name">{item.name}</p>
                <p class="testimonial7__role">{item.role}</p>
              </div>
            </div>
            <q class="testimonial7__quote">{item.content}</q>
          </article>
        ))}
      </div>

      <div class="testimonial7__track testimonial7__track--backward">
        {[...secondRow, ...secondRow].map((item, index) => (
          <article class="testimonial7__card" aria-label={`Opinia ${item.name}`}>
            <div class="testimonial7__person">
              <img src={item.avatar} alt={item.name} loading={index < secondRow.length ? 'eager' : 'lazy'} />
              <div>
                <p class="testimonial7__name">{item.name}</p>
                <p class="testimonial7__role">{item.role}</p>
              </div>
            </div>
            <q class="testimonial7__quote">{item.content}</q>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .testimonial7 {
    padding: 8rem 0;
    overflow: hidden;
  }

  .testimonial7__inner {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .testimonial7__header {
    display: flex;
    max-width: 48rem;
    margin: 0 auto;
    flex-direction: column;
    gap: 1.5rem;
    text-align: center;
  }

  .testimonial7__badge {
    display: inline-flex;
    width: fit-content;
    margin: 0 auto;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem;
  }

  .testimonial7__title {
    margin: 0;
    font-family: var(--font-headline);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
  }

  .testimonial7__description,
  .testimonial7__role,
  .testimonial7__quote {
    margin: 0;
    color: var(--color-muted-foreground);
  }

  .testimonial7__rows {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    mask-image: linear-gradient(90deg, transparent, black 10%, black 90%, transparent);
  }

  .testimonial7__track {
    display: flex;
    gap: 1rem;
    width: max-content;
    animation-duration: 38s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }

  .testimonial7__track--forward {
    animation-name: marquee-forward;
  }

  .testimonial7__track--backward {
    animation-name: marquee-backward;
  }

  .testimonial7__card {
    width: min(24rem, 80vw);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: var(--color-card);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
  }

  .testimonial7__person {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .testimonial7__person img {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid var(--color-border);
  }

  .testimonial7__name {
    margin: 0;
  }

  @keyframes marquee-forward {
    from { transform: translateX(0); }
    to { transform: translateX(calc(-50% - 0.5rem)); }
  }

  @keyframes marquee-backward {
    from { transform: translateX(calc(-50% - 0.5rem)); }
    to { transform: translateX(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial7__track {
      animation: none;
      width: 100%;
      flex-wrap: wrap;
    }
  }
</style>