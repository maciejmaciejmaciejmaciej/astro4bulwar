# Copy this file to `.env.client.local` and fill it once per client.
# Then run `node SCRIPTS/bootstrap-client-config.js --write`.
#
# This is the only local source of truth you should edit for a new client.

# Public URLs
CLIENT_SITE_URL="https://example-client.pl"
CLIENT_WORDPRESS_BASE_URL="https://example-client.pl"
CLIENT_ASTRO_BASE_PATH="/astro/"
CLIENT_REACT_BASE_PATH="/react/"

# Local deploy access
CLIENT_SSH_HOST="example-client.ssh.dhosting.pl"
CLIENT_SSH_USER="example-user"
CLIENT_SSH_KEY_PATH="./id_rsa"

# Remote paths
CLIENT_REMOTE_ASTRO_SOURCE_ROOT="/home/klient.dhosting.pl/example-user/astro-site"
CLIENT_REMOTE_ASTRO_PUBLIC_ROOT="/home/klient.dhosting.pl/example-user/domains/example-client.pl/public_html/astro"
CLIENT_REMOTE_ASTRO_BACKUP_ROOT="/home/klient.dhosting.pl/example-user/deploy_backups/astro"
CLIENT_REMOTE_REACT_PUBLIC_ROOT="/home/klient.dhosting.pl/example-user/domains/example-client.pl/public_html/react"
CLIENT_REMOTE_WP_ROOT="/home/klient.dhosting.pl/example-user/domains/example-client.pl/public_html"

# Bridge / WordPress runtime config
CLIENT_BRIDGE_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
CLIENT_BRIDGE_STORE_ORIGIN_LINE1="ul. Przykladowa 10"
CLIENT_BRIDGE_STORE_ORIGIN_CITY="Warszawa"
CLIENT_BRIDGE_STORE_ORIGIN_POSTAL_CODE="00-001"
CLIENT_BRIDGE_STORE_ORIGIN_COUNTRY="PL"
CLIENT_BRIDGE_DELIVERY_BASE_FEE="10"
CLIENT_BRIDGE_DELIVERY_PRICE_PER_KM="9"
CLIENT_BRIDGE_FREE_DELIVERY_THRESHOLD="800"
CLIENT_BRIDGE_TIMEZONE="Europe/Warsaw"
CLIENT_BRIDGE_SPECIAL_PRODUCT_ID="53"
CLIENT_BRIDGE_MAKE_WEBHOOK_URL=""

# Page-builder WordPress credentials
CLIENT_PAGE_BUILDER_WORDPRESS_USERNAME="your-wordpress-username"
CLIENT_PAGE_BUILDER_WORDPRESS_APPLICATION_PASSWORD="your-wordpress-application-password"

# Page-builder Firebase credentials
CLIENT_FIREBASE_PROJECT_ID="your-firebase-project-id"
CLIENT_FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
CLIENT_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"

# Optional page-builder overrides
# CLIENT_FIREBASE_DRAFT_COLLECTION="pageBuilderDrafts"
# CLIENT_FIREBASE_DATABASE_ID="(default)"
# CLIENT_FIREBASE_APP_NAME="page-builder-runtime"

# Optional AI Studio / app integration values
# CLIENT_GEMINI_API_KEY=""
# CLIENT_APP_URL="https://example-client.pl/react/"